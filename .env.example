# Copy to `.env` and fill in. See README for provider details.

# --- LLM: chat / tool-calling (any OpenAI-compatible endpoint) ---
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# Comma-separated, primary first. A 2nd entry is the fallback model (tried if the primary errors):
#   LLM_MODELS=openai/gpt-4o-mini,meta-llama/llama-3.1-8b-instruct
LLM_MODELS=openai/gpt-4o-mini
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=2

# --- Embeddings  ---
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small

# --- Agent run budgets ---
MAX_TURNS=10
RUN_BUDGET_S=60

# --- Data / databases ---
SOURCE_DB_PATH=data/data.sqlite
APP_DB_PATH=data/app.sqlite
AS_OF_DATE=2026-06-24

# --- Retrieval (RAG over the guidelines corpus) ---
GUIDELINES_DIR=guidelines
CACHE_DIR=.cache
RETRIEVAL_TOP_K = 3

# --- Segments ---
MAX_SEGMENT_REACH= 0.85


